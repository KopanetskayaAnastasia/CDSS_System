# ============================================
# CDSS - Система поддержки принятия врачебных решений
# Копируйте этот файл в .env и добавьте свои секреты
# ============================================

# ========== POSTGRESQL ==========
POSTGRES_DB=cdss_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ========== CHROMADB ==========
CHROMA_PATH=/app/chroma_db
CHROMA_COLLECTION=clinical_guidelines

# ========== ML MODELS ==========
EMBEDDING_MODEL=intfloat/multilingual-e5-small
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-2-v2

# ========== SEARCH PARAMETERS ==========
SEARCH_K=5
ALPHA=0.7
CHUNK_SIZE=256
CHUNK_OVERLAP=51

# ========== GIGACHAT API ==========
# Получите ключи на https://developers.sber.ru
GIGACHAT_CREDENTIALS=your_authorization_key_here
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_API_URL=https://gigachat.devices.sberbank.ru/api/v1
GIGACHAT_TIMEOUT=60

# ========== JWT AUTHENTICATION ==========
JWT_SECRET_KEY=change-this-to-random-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# ========== LLM SETTINGS ==========
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2000

# ========== ADMIN USER ==========
ADMIN_LOGIN=admin
ADMIN_PASSWORD=change_admin_password
ADMIN_FULL_NAME=System Administrator
ADMIN_SPECIALTY=Administrator

# ========== PATHS ==========
UPLOAD_PATH=./docs/clinical_guidelines
LOGS_PATH=./logs
MAX_FILE_SIZE_MB=50

# ========== MIS FHIR INTEGRATION ==========
MIS_FHIR_URL=your_url
MIS_API_KEY=your_api